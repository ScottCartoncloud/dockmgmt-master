# E2E Test Environment Configuration
# Copy this file to .env.testing and fill in your values

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# These should point to a test/staging Supabase project
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
PLAYWRIGHT_SUPABASE_URL=https://your-project.supabase.co
PLAYWRIGHT_SUPABASE_KEY=your-anon-key

# =============================================================================
# TEST USER CREDENTIALS
# =============================================================================
# Create these users in your test Supabase project with appropriate roles

# Admin user (can manage all settings, users, delete bookings)
TEST_ADMIN_EMAIL=test-admin@example.com
TEST_ADMIN_PASSWORD=SecureTestPassword123!

# Operator user (can create/edit bookings, view calendar)
TEST_OPERATOR_EMAIL=test-operator@example.com
TEST_OPERATOR_PASSWORD=SecureTestPassword123!

# Viewer user (read-only access)
TEST_VIEWER_EMAIL=test-viewer@example.com
TEST_VIEWER_PASSWORD=SecureTestPassword123!

# Super User (can access all tenants, full admin access)
TEST_SUPER_USER_EMAIL=test-super@example.com
TEST_SUPER_USER_PASSWORD=SecureTestPassword123!

# =============================================================================
# TEST DATA
# =============================================================================
# Name of the test tenant
TEST_TENANT_NAME=E2E Test Tenant

# Carrier booking link UUID (create a carrier and get its booking_link_id)
TEST_CARRIER_BOOKING_LINK_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# =============================================================================
# INVITE FLOW TESTING (Optional)
# =============================================================================
# To test the invite flow, create an invite and use its token
TEST_INVITE_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TEST_INVITE_EMAIL=invited-user@example.com

# =============================================================================
# PLAYWRIGHT CONFIGURATION
# =============================================================================
# Base URL for tests (default: http://localhost:8080)
PLAYWRIGHT_BASE_URL=http://localhost:8080

# Set to 'true' in CI environments
CI=false
